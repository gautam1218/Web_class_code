      "seed": 365015150,
      "version": 9,
      "versionNonce": 1009370030,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771993050707,
      "link": null,
      "locked": false,
      "text": "const p2 = new Promise((resolve,reject)=>{\n    setTimeout(() => {\n        resolve(\"p2\");\n    }, 100);\n});\n\n\n\nconst p3 = new Promise((resolve,reject)=>{\n    setTimeout(() => {\n        resolve(\"p3\");\n    }, 150);\n});\n\n\nconst p4 = new Promise((resolve,reject)=>{\n    setTimeout(() => {\n        resolve(\"p4\");\n    }, 130);\n});\n\nconst results = Promise.all([p1,p2,p3,p4]);\nresults.then((response)=>console.log(response)); ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "const p2 = new Promise((resolve,reject)=>{\n    setTimeout(() => {\n        resolve(\"p2\");\n    }, 100);\n});\n\n\n\nconst p3 = new Promise((resolve,reject)=>{\n    setTimeout(() => {\n        resolve(\"p3\");\n    }, 150);\n});\n\n\nconst p4 = new Promise((resolve,reject)=>{\n    setTimeout(() => {\n        resolve(\"p4\");\n    }, 130);\n});\n\nconst results = Promise.all([p1,p2,p3,p4]);\nresults.then((response)=>console.log(response)); ",
      "autoResize": true,
      "lineHeight": 1.25
    },
