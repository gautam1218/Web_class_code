    {
      "id": "DKbDe4LwSx1e68CupJ0xn",
      "type": "text",
      "x": 397.328125,
      "y": 307.7265625,
      "width": 474.879638671875,
      "height": 575,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
