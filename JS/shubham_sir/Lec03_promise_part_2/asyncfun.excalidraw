      "isDeleted": false,
      "boundElements": [],
      "updated": 1771995284790,
      "link": null,
      "locked": false,
      "text": "const p1 = new Promise((reolve,reject)=>{\n    setTimeout(() => {\n        console.log(\"hello\");\n    }, 2000);\n})\n\nconsole.log(\"start\");\n\nasync function fun() {\n    console.log(\"async start\");\n    const response = await p1;\n    console.log(p1);\n    console.log(\"async end\");\n}\n\nfun();\nconsole.log(\"end\");",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "const p1 = new Promise((reolve,reject)=>{\n    setTimeout(() => {\n        console.log(\"hello\");\n    }, 2000);\n})\n\nconsole.log(\"start\");\n\nasync function fun() {\n    console.log(\"async start\");\n    const response = await p1;\n    console.log(p1);\n    console.log(\"async end\");\n}\n\nfun();\nconsole.log(\"end\");",
      "autoResize": true,
      "lineHeight": 1.25
    },
