      "updated": 1771996730657,
      "link": null,
      "locked": false,
      "text": "async function fun() {\n    const response = await p1;\n    return response;\n}\n\n// await fun(). // we cant use await outside async fun(it will no effect)\n  \nfun().then((data)=>console.log(data)).catch((err)=>console.log(err));\n\nasync function fun2() {\n    const data = await fun();\n    console.log(data);\n}\n\nfun2();",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "async function fun() {\n    const response = await p1;\n    return response;\n}\n\n// await fun(). // we cant use await outside async fun(it will no effect)\n  \nfun().then((data)=>console.log(data)).catch((err)=>console.log(err));\n\nasync function fun2() {\n    const data = await fun();\n    console.log(data);\n}\n\nfun2();",
      "autoResize": true,
      "lineHeight": 1.25
    },
